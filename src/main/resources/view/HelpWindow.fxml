<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Scene?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.stage.Stage?>

<fx:root resizable="true" title="Help" type="javafx.stage.Stage" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <icons>
    <Image url="@/images/help_icon.png" />
  </icons>
  <scene>
    <Scene>
      <stylesheets>
        <URL value="@HelpWindow.css" />
      </stylesheets>

      <VBox id="helpWindowContainer" spacing="0">
        <children>
          <TableView fx:id="commandTable" VBox.vgrow="ALWAYS">
            <columns>
              <TableColumn fx:id="commandCol" text="Command" prefWidth="180" />
              <TableColumn fx:id="formatCol" text="Format" prefWidth="280" />
              <TableColumn fx:id="descCol" text="Description" prefWidth="360" />
            </columns>
          </TableView>
          <HBox id="urlBox" alignment="CENTER_LEFT" spacing="8">
            <children>
              <Label fx:id="helpMessage" text="Label" />
              <Button fx:id="copyButton" mnemonicParsing="false" onAction="#copyUrl" text="Copy URL" />
            </children>
            <padding>
              <Insets bottom="8.0" left="10.0" right="10.0" top="8.0" />
            </padding>
          </HBox>
        </children>
      </VBox>
    </Scene>
  </scene>
</fx:root>
